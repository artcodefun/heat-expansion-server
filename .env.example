# Example .env file for Heat Expansion Server

# Shared
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Game Service
GAME_PORT=8080
GAME_DB_URL=postgres://user:password@localhost:5432/heatdb?sslmode=disable
GAME_JWT_SECRET=your_game_jwt_secret_here
GAME_STATIC_BASE_URL=https://static.heat-expansion.com/game
GAME_MIGRATIONS_TABLE=game_schema_migrations

# Auth Service
AUTH_PORT=8081
AUTH_DB_URL=postgres://user:password@localhost:5432/heatdb?sslmode=disable
AUTH_JWT_SECRET=your_auth_jwt_secret_here
AUTH_MIGRATIONS_TABLE=auth_schema_migrations
AUTH_INTEGRATION_EXCHANGE=auth.integration

# Billing Service
BILLING_PORT=8082
BILLING_DB_URL=postgres://user:password@localhost:5432/heatdb?sslmode=disable
BILLING_JWT_SECRET=your_billing_jwt_secret_here
BILLING_MIGRATIONS_TABLE=billing_schema_migrations
BILLING_INTEGRATION_EXCHANGE=billing.integration
YOOKASSA_SHOP_ID=your_yookassa_shop_id_here
YOOKASSA_SECRET_KEY=your_yookassa_secret_key_here

# Auth SMTP (for password reset emails)
AUTH_SMTP_HOST=smtp.yourprovider.com
AUTH_SMTP_USER=noreply@yourcompany.com
AUTH_SMTP_PASSWORD=your_smtp_password_or_app_password
AUTH_SMTP_FROM=noreply@yourcompany.com

# OpenTelemetry — leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable (no-op mode for local dev)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=heat-expansion

# Grafana Cloud credentials (consumed by otel-collector only, not the Go app)
# API key must have logs:write, metrics:write, and traces:write scopes
# OTLP gateway endpoint and instance ID are shown in Grafana Cloud → My Account → your stack → OpenTelemetry
GRAFANA_API_KEY=your_grafana_cloud_api_key_here
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-X.grafana.net/otlp
GRAFANA_INSTANCE_ID=000000

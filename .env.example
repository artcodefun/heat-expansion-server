# Example .env file for Heat Expansion Server
GAME_PORT=8080
GAME_DB_URL=postgres://user:password@localhost:5432/heatdb?sslmode=disable
GAME_JWT_SECRET=your_jwt_secret_here
GAME_STATIC_BASE_URL=http://localhost:8080/assets
GAME_ASSETS_DIR=./assets

# Optional: migration state table name used by golang-migrate (stored in public schema)
GAME_MIGRATIONS_TABLE=game_schema_migrations
